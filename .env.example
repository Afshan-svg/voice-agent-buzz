# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
PUBLIC_URL=http://localhost:3000
# On Render, PUBLIC_URL is auto-set from RENDER_EXTERNAL_URL
# For local Twilio testing, use your ngrok HTTPS URL:
# PUBLIC_URL=https://your-subdomain.ngrok-free.app

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/hotel_receptionist?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=shimmer
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Knowledge Base
UPLOAD_DIR=./uploads
KNOWLEDGE_MAX_FILE_SIZE=10485760
KNOWLEDGE_CHUNK_SIZE=1000
KNOWLEDGE_CHUNK_OVERLAP=200
KNOWLEDGE_SEARCH_LIMIT=5
KNOWLEDGE_MIN_SIMILARITY=0.7

# Twilio (use your own credentials from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_HUMAN_TRANSFER_NUMBER=+15559876543

# Hotel
HOTEL_NAME=BuzznessAI Luxury Hotel

# Dashboard Auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

# WhatsApp
WHATSAPP_AUTO_SEND_CONFIRMATION=true
WHATSAPP_AUTO_SEND_CANCELLATION=true

# Dev: outbound test call target (defaults to TWILIO_HUMAN_TRANSFER_NUMBER)
TEST_CALL_TO_NUMBER=+15559876543
