generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CallStatus {
  ACTIVE
  COMPLETED
  FAILED
  TRANSFERRED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

enum KnowledgeFileType {
  PDF
  DOCX
  TXT
}

enum WhatsAppMessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
  READ
}

enum WhatsAppMessageType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLATION
}

model Room {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  price     Int
  capacity  Int
  available Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@index([available])
  @@map("rooms")
}

model Booking {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @unique @map("booking_id")
  guestName String        @map("guest_name")
  phone     String
  email     String
  roomType  String        @map("room_type")
  checkIn   DateTime      @map("check_in") @db.Date
  checkOut  DateTime      @map("check_out") @db.Date
  guests    Int
  status    BookingStatus @default(CONFIRMED)
  totalPrice Int?         @map("total_price")
  callId    String?       @map("call_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  room Room? @relation(fields: [roomType], references: [name])
  call Call? @relation(fields: [callId], references: [id])
  whatsappMessages WhatsAppMessage[]

  @@index([bookingId])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

enum CallChannel {
  PHONE
  WEB
}

model Call {
  id           String      @id @default(uuid()) @db.Uuid
  callSid      String      @unique @map("call_sid")
  callerNumber String      @map("caller_number")
  status       CallStatus  @default(ACTIVE)
  channel      CallChannel @default(PHONE)
  startTime    DateTime    @default(now()) @map("start_time")
  endTime      DateTime?  @map("end_time")
  duration     Int?
  sentiment    Sentiment?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  bookings    Booking[]
  transcript  Transcript?
  summary     CallSummary?

  @@index([callerNumber])
  @@index([status])
  @@index([startTime])
  @@map("calls")
}

model Transcript {
  id        String   @id @default(uuid()) @db.Uuid
  callId    String   @unique @map("call_id") @db.Uuid
  content   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("transcripts")
}

model CallSummary {
  id          String    @id @default(uuid()) @db.Uuid
  callId      String    @unique @map("call_id") @db.Uuid
  intent      String
  summary     String    @db.Text
  sentiment   Sentiment
  actionItems Json      @map("action_items")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("call_summaries")
}

model KnowledgeFile {
  id           String            @id @default(uuid()) @db.Uuid
  filename     String
  originalName String            @map("original_name")
  mimeType     String            @map("mime_type")
  fileType     KnowledgeFileType @map("file_type")
  fileSize     Int               @map("file_size")
  storagePath  String            @map("storage_path")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  chunks KnowledgeChunk[]

  @@index([fileType])
  @@map("knowledge_files")
}

model KnowledgeChunk {
  id         String                      @id @default(uuid()) @db.Uuid
  fileId     String                      @map("file_id") @db.Uuid
  content    String                      @db.Text
  chunkIndex Int                         @map("chunk_index")
  embedding  Unsupported("vector(1536)")?
  metadata   Json?
  createdAt  DateTime                    @default(now()) @map("created_at")

  file KnowledgeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@map("knowledge_chunks")
}

model WhatsAppMessage {
  id           String                @id @default(uuid()) @db.Uuid
  messageSid   String?               @unique @map("message_sid")
  bookingId    String?               @map("booking_id")
  toPhone      String                @map("to_phone")
  fromPhone    String                @map("from_phone")
  messageType  WhatsAppMessageType   @map("message_type")
  body         String                @db.Text
  status       WhatsAppMessageStatus @default(QUEUED)
  errorMessage String?               @map("error_message") @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [bookingId])

  @@index([bookingId])
  @@index([status])
  @@index([messageType])
  @@index([createdAt])
  @@map("whatsapp_messages")
}
